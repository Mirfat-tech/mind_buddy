<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/habit_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/habit_today_widget_bg"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/habit_widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Habits"
            android:textColor="#202235"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/habit_widget_view_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="View all"
            android:textColor="#515D8E"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/habit_chip_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/habit_widget_chip_incomplete"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        android:text="Habit"
        android:textColor="#202235"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/habit_chip_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@drawable/habit_widget_chip_incomplete"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        android:text="Habit"
        android:textColor="#202235"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/habit_chip_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@drawable/habit_widget_chip_incomplete"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        android:text="Habit"
        android:textColor="#202235"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/habit_chip_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@drawable/habit_widget_chip_incomplete"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        android:text="Habit"
        android:textColor="#202235"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/habit_chip_5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@drawable/habit_widget_chip_incomplete"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        android:text="Habit"
        android:textColor="#202235"
        android:textSize="12sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/habit_chip_6"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@drawable/habit_widget_chip_incomplete"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        android:text="Habit"
        android:textColor="#202235"
        android:textSize="12sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/habit_chip_more"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@drawable/habit_widget_chip_more"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        android:text="+0 more"
        android:textColor="#4D5272"
        android:textSize="12sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/habit_widget_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Could not sync. Tap again."
        android:textColor="#A04646"
        android:textSize="11sp"
        android:visibility="gone" />

</LinearLayout>
